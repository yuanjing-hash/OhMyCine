# IDE / Editor
# ====================

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ====================
# Node / JavaScript (player, hub)
# ====================

node_modules/
dist/
.nuxt/
.output/
*.local
.env
.env.*
!.env.example

# Vite
*.local

# TypeScript
*.tsbuildinfo

# ====================
# Rust / Tauri (player/src-tauri)
# ====================

target/
**/*.rs.bk

# Tauri
src-tauri/target/
player/src-tauri/lib/libmpv.dll.a

# ====================
# Go (server, cli)
# ====================

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
omc
ohmycine-server

# Test binary
*.test

# Go workspace
go.work
go.work.sum

# Vendor (uncomment if not vendoring)
# vendor/

